{
  "name": "vr-frontend-teste-mfe",
  "private": true,
  "version": "1.0.0",
  "description": "Teste tecnico VR - Micro frontend com Module Federation",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently -k -n header,footer,cards,shell -c yellow,magenta,cyan,green \"npm:start -w @vr/header\" \"npm:start -w @vr/footer\" \"npm:start -w @vr/cards\" \"npm:start -w @vr/shell\"",
    "build": "npm run build -w @vr/shared && npm run build -w @vr/header && npm run build -w @vr/footer && npm run build -w @vr/cards && npm run build -w @vr/shell",
    "build:static": "npm run build && npm run build-storybook && node scripts/combine-dist.js",
    "test": "jest --projects packages/shared packages/shell packages/header packages/footer packages/cards",
    "test:watch": "jest --projects packages/shared packages/shell packages/header packages/footer packages/cards --watch",
    "test:coverage": "jest --projects packages/shared packages/shell packages/header packages/footer packages/cards --coverage",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html}\" --ignore-path .gitignore",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.4",
    "@storybook/addon-essentials": "^8.6.4",
    "@storybook/addon-webpack5-compiler-swc": "^1.0.6",
    "@storybook/blocks": "^8.6.4",
    "@storybook/react": "^8.6.4",
    "@storybook/react-webpack5": "^8.6.4",
    "@tailwindcss/postcss": "^4.0.9",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "typescript-eslint": "^8.0.0",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "lint-staged": "^15.4.3",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.4.2",
    "storybook": "^8.6.4",
    "style-loader": "^3.3.4",
    "tailwindcss": "^4.0.9",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4",
    "webpack-merge": "^5.10.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
